# ============================================================
#  BABA FOOD Loyalty System — Variabili d'Ambiente
#  Copia questo file in "backend/.env" e compila i valori.
# ============================================================

# Porta del server (default: 3000)
PORT=3000

# URL base del sito (per generare link corretti nelle email/QR)
BASE_URL=http://localhost:3000

# ------------------------------------------------------------
# Apple Wallet (opzionale — richiede Apple Developer account)
# Vedi SETUP.md sezione "Apple Wallet (produzione)"
# ------------------------------------------------------------
# APPLE_TEAM_IDENTIFIER=XXXXXXXXXX
# APPLE_PASS_TYPE_IDENTIFIER=pass.com.babafood.loyalty
# APPLE_CERT_PATH=./certs/signerCert.pem
# APPLE_KEY_PATH=./certs/signerKey.pem
# APPLE_WWDR_PATH=./certs/wwdr.pem

# ------------------------------------------------------------
# Google Wallet (opzionale — richiede Google Cloud project)
# Vedi SETUP.md sezione "Google Wallet (produzione)"
# ------------------------------------------------------------
# GOOGLE_APPLICATION_CREDENTIALS=./certs/google-service-account.json
# GOOGLE_ISSUER_ID=3388000000022795111
